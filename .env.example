# Base de donnees PostgreSQL
POSTGRES_USER=floouzz
POSTGRES_PASSWORD=floouzz_secret
POSTGRES_DB=floouzz
DATABASE_URL=postgresql+asyncpg://floouzz:floouzz_secret@db:5432/floouzz

# Application
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Sources de signaux
SERPAPI_KEY=
APIFY_TOKEN=
ANTHROPIC_API_KEY=

# Webhook (token pour securiser l'endpoint n8n)
WEBHOOK_TOKEN=
